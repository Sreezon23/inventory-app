{% extends 'base.html.twig' %}

{% block title %}{{ inventory.title }}{% endblock %}

{% block body %}
    <div class="container py-5">
        
        {# --- Header Section --- #}
        <div class="d-flex align-items-center justify-content-between mb-4">
            <div>
                <h1 class="display-5 fw-bold text-primary mb-1">{{ inventory.title }}</h1>
                <p class="text-muted mb-0">
                    <i class="bi bi-person-circle me-1"></i> Created by <strong>{{ inventory.creator.name }}</strong> 
                    on {{ inventory.createdAt|date('M d, Y') }}
                </p>
            </div>

            {# --- Action Buttons (Only for Owner) --- #}
            {% if app.user and app.user.id == inventory.creator.id %}
                <div class="btn-group shadow-sm">
                    <a href="{{ path('inventory_edit', {id: inventory.id}) }}" class="btn btn-outline-secondary">
                        <i class="bi bi-pencil-square me-1"></i> Edit
                    </a>
                    <button class="btn btn-outline-danger" data-bs-toggle="modal" data-bs-target="#deleteModal">
                        <i class="bi bi-trash me-1"></i> Delete
                    </button>
                </div>
            {% endif %}
        </div>

        <div class="row g-4">
            
            {# --- Left Column: Details & Image --- #}
            <div class="col-lg-7">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-body p-4">
                        
                        {# Image or Placeholder #}
                        {% if inventory.imageUrl %}
                            <div class="mb-4 rounded-3 overflow-hidden shadow-sm">
                                
                                <img src="{{ inventory.imageUrl }}" class="img-fluid w-100 object-fit-cover" style="max-height: 400px;" alt="{{ inventory.title }}">
                            </div>
                        {% else %}
                             <div class="mb-4 bg-light rounded-3 d-flex align-items-center justify-content-center text-muted" style="height: 250px;">
                                <span><i class="bi bi-image me-2"></i>No Cover Image</span>
                            </div>
                        {% endif %}

                        <h4 class="fw-bold text-secondary mb-3">About this Collection</h4>
                        <p class="lead fs-6">{{ inventory.description|nl2br }}</p>

                        <hr class="my-4 text-muted opacity-25">

                        <div class="d-flex gap-4">
                            <div>
                                <small class="text-uppercase text-muted fw-bold d-block mb-1">Category</small>
                                <span class="badge bg-light text-dark border fs-6 px-3 py-2">
                                    <i class="bi bi-tag-fill me-1 text-primary"></i> {{ inventory.category }}
                                </span>
                            </div>
                            <div>
                                <small class="text-uppercase text-muted fw-bold d-block mb-1">Visibility</small>
                                {% if inventory.isPublic %}
                                    <span class="badge bg-success bg-opacity-10 text-success border border-success fs-6 px-3 py-2">
                                        <i class="bi bi-globe me-1"></i> Public
                                    </span>
                                {% else %}
                                    <span class="badge bg-secondary bg-opacity-10 text-secondary border border-secondary fs-6 px-3 py-2">
                                        <i class="bi bi-lock-fill me-1"></i> Private
                                    </span>
                                {% endif %}
                            </div>
                        </div>

                        {# Tags Section (Optional) #}
                        {% if inventory.tags|length > 0 %}
                            <div class="mt-4">
                                <small class="text-uppercase text-muted fw-bold d-block mb-2">Tags</small>
                                <div>
                                    {% for tag in inventory.tags %}
                                        <span class="badge rounded-pill text-bg-secondary me-1">#{{ tag.name }}</span>
                                    {% endfor %}
                                </div>
                            </div>
                        {% endif %}
                    </div>
                </div>
            </div>

            {# --- Right Column: Items Preview --- #}
            <div class="col-lg-5">
                <div class="card border-0 shadow-sm h-100 bg-light">
                    <div class="card-header bg-transparent border-0 pt-4 px-4 d-flex justify-content-between align-items-center">
                        <h4 class="mb-0 fw-bold"><i class="bi bi-collection me-2"></i>Items</h4>
                        <span class="badge bg-primary rounded-pill">{{ inventory.items|length }}</span>
                    </div>
                    
                    <div class="card-body px-4 pb-4">
                        {% if inventory.items|length > 0 %}
                            <div class="list-group list-group-flush rounded-3 shadow-sm mb-4">
                                {% for item in inventory.items|slice(0, 5) %}
                                    <div class="list-group-item list-group-item-action d-flex justify-content-between align-items-center p-3">
                                        <div>
                                            <div class="fw-bold text-dark">{{ item.customId }}</div>
                                            <small class="text-muted"><i class="bi bi-clock"></i> {{ item.createdAt|date('M d') }}</small>
                                        </div>
                                        <div class="text-end">
                                            <span class="badge bg-danger bg-opacity-10 text-danger rounded-pill">
                                                <i class="bi bi-heart-fill me-1"></i> {{ item.likes|length }}
                                            </span>
                                        </div>
                                    </div>
                                {% endfor %}
                            </div>
                            
                            {% if inventory.items|length > 5 %}
                                <div class="text-center text-muted small mb-3">
                                    And {{ inventory.items|length - 5 }} more items...
                                </div>
                            {% endif %}

                            <div class="d-grid">
                                <a href="{{ path('inventory_item_index', {inventory_id: inventory.id}) }}" class="btn btn-primary btn-lg shadow-sm">
                                    View Full Inventory <i class="bi bi-arrow-right ms-2"></i>
                                </a>
                            </div>
                        {% else %}
                            <div class="text-center py-5 text-muted">
                                <i class="bi bi-box-seam display-1 mb-3 opacity-50"></i>
                                <p class="mb-3">This inventory is empty.</p>
                                {% if app.user and app.user.id == inventory.creator.id %}
                                    <a href="{{ path('inventory_item_new', {inventory_id: inventory.id}) }}" class="btn btn-outline-primary btn-sm">
                                        + Add First Item
                                    </a>
                                {% endif %}
                            </div>
                        {% endif %}
                    </div>
                </div>
            </div>
        </div>
    </div>

    {# --- Delete Confirmation Modal --- #}
    <div class="modal fade" id="deleteModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg">
                <div class="modal-header bg-danger text-white border-0">
                    <h5 class="modal-title fw-bold"><i class="bi bi-exclamation-triangle-fill me-2"></i>Delete Inventory</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body p-4 text-center">
                    <p class="fs-5 mb-1">Are you sure you want to delete <strong>{{ inventory.title }}</strong>?</p>
                    <p class="text-muted small">This action cannot be undone and will delete all items inside.</p>
                </div>
                <div class="modal-footer border-0 justify-content-center pb-4">
                    <button type="button" class="btn btn-light px-4 border" data-bs-dismiss="modal">Cancel</button>
                    <form method="post" action="{{ path('inventory_delete', {id: inventory.id}) }}">
                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ inventory.id) }}">
                        <button type="submit" class="btn btn-danger px-4 fw-bold shadow-sm">Yes, Delete It</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
{% endblock %}