{% extends 'base.html.twig' %}

{% block title %}{{ inventory.name }} - Inventory Details{% endblock %}

{% block body %}
<div class="row">
    <div class="col-lg-8">
        <div class="card shadow-lg border-0 mb-4">
            <div class="card-body p-5">
                <div class="d-flex justify-content-between align-items-start mb-4">
                    <div>
                        <h2 class="mb-1">
                            <i class="fas fa-box text-primary"></i> {{ inventory.name }}
                        </h2>
                        <p class="text-muted mb-0">
                            Access: <strong>{{ inventory.accessLevel }}</strong> •
                            Version: <span class="badge bg-primary">v{{ inventory.version }}</span>
                        </p>
                    </div>
                    <span class="text-muted small text-end">
                        Created: {{ inventory.createdAt|date('M d, Y H:i') }}<br>
                        Updated: {{ inventory.updatedAt|date('M d, Y H:i') }}
                    </span>
                </div>

                {% if inventory.description %}
                    <h5 class="mb-2">Description</h5>
                    <p class="text-muted">{{ inventory.description }}</p>
                {% endif %}

                <hr class="my-4">

                <h5 class="mb-3">
                    <i class="fas fa-tags text-secondary"></i> Custom Fields
                </h5>

                {% if inventory.customFields %}
                    <pre class="bg-light p-3 rounded font-monospace small mb-0">
{{ inventory.customFields|json_encode(constant('JSON_PRETTY_PRINT')) }}
                    </pre>
                {% else %}
                    <p class="text-muted fst-italic">No custom fields defined.</p>
                {% endif %}
            </div>
        </div>

        <div class="d-flex gap-2">
            <a href="{{ path('inventory_index') }}" class="btn btn-outline-secondary">
                <i class="fas fa-arrow-left"></i> Back to list
            </a>
            <a href="{{ path('inventory_edit', { id: inventory.id }) }}" class="btn btn-primary">
                <i class="fas fa-edit"></i> Edit Inventory
            </a>
            <form method="post" action="{{ path('inventory_delete', { id: inventory.id }) }}" onsubmit="return confirm('Delete this inventory permanently?');">
                <input type="hidden" name="token" value="{{ csrf_token('delete-inventory-' ~ inventory.id) }}">
                <button class="btn btn-outline-danger">
                    <i class="fas fa-trash"></i> Delete
                </button>
            </form>
        </div>
    </div>
</div>
{% endblock %}
