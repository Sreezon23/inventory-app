{% extends 'base.html.twig' %}

{% block title %}Items - {{ inventory.name }}{% endblock %}

{% block body %}
<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <a href="{{ path('inventory_show', {'id': inventory.id}) }}" class="btn btn-secondary">
            ← Back to {{ inventory.name }}
        </a>
        <h1>📦 Items ({{ items|length }})</h1>
        <a href="{{ path('item_new', {'inventoryId': inventory.id}) }}" class="btn btn-primary btn-lg">
            <i class="fas fa-plus"></i> Add Item
        </a>
    </div>

    {% for message in app.flashes('success') %}
        <div class="alert alert-success">{{ message }}</div>
    {% endfor %}

    {% if items|length > 0 %}
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>ID</th>
                        <th>Text 1</th>
                        <th>Text 2</th>
                        <th>Text 3</th>
                        <th>Number 1</th>
                        <th>Number 2</th>
                        <th>Date 1</th>
                        <th>Created</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    {% for item in items %}
                        <tr>
                            <td>#{{ item.id }}</td>
                            <td>{{ item.textField1 ?? '-' }}</td>
                            <td>{{ item.textField2 ?? '-' }}</td>
                            <td>{{ item.textField3 ?? '-' }}</td>
                            <td>{{ item.numberField1 ?? '-' }}</td>
                            <td>{{ item.numberField2 ?? '-' }}</td>
                            <td>{{ item.dateField1 ? item.dateField1|date('Y-m-d') : '-' }}</td>
                            <td>{{ item.createdAt|date('M d, Y') }}</td>
                            <td>
                                <a href="{{ path('item_edit', {'inventoryId': inventory.id, 'id': item.id}) }}" class="btn btn-sm btn-warning">Edit</a>
                                {{ include('item/_delete_form.html.twig', {'inventory': inventory, 'item': item}) }}
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    {% else %}
        <div class="text-center py-5">
            <i class="fas fa-boxes fa-3x text-muted mb-3"></i>
            <h3>No items yet</h3>
            <p class="text-muted">Get started by adding your first item.</p>
            <a href="{{ path('item_new', {'inventoryId': inventory.id}) }}" class="btn btn-primary btn-lg">Add First Item</a>
        </div>
    {% endif %}
</div>
{% endblock %}
