{% extends 'base.html.twig' %}

{% block title %}Edit Inventory{% endblock %}

{% block body %}
    <div class="container mt-4">
        <h1>Edit Inventory</h1>

        {{ form_start(form) }}
            {{ form_widget(form) }}
            <button class="btn btn-primary mt-3">{{ button_label|default('Update') }}</button>
        {{ form_end(form) }}

        <div class="mt-3">
            <a href="{{ path('inventory_index') }}" class="btn btn-secondary">Back to list</a>
            
            {# Include the delete form if you have one #}
            <div class="d-inline-block ms-2">
                {{ include('inventory/_delete_form.html.twig') }}
            </div>
        </div>
    </div>
{% endblock %}