{% extends 'base.html.twig' %}

{% block title %}Edit {{ inventory.name }} - Inventory Manager{% endblock %}

{% block body %}
<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="card shadow-lg border-0">
            <div class="card-body p-5">
                <div class="mb-5 d-flex justify-content-between align-items-center">
                    <div>
                        <h2 class="mb-2">
                            <i class="fas fa-edit text-primary"></i> Edit Inventory
                        </h2>
                        <p class="text-muted mb-0">
                            You are editing version <strong>v{{ inventory.version }}</strong>
                        </p>
                    </div>
                    <span class="badge bg-light text-muted">
                        Last updated: {{ inventory.updatedAt|date('M d, Y H:i') }}
                    </span>
                </div>

                <form method="post" novalidate class="needs-validation">
                    {{ form_start(form) }}

                    <div class="mb-4">
                        {{ form_label(form.name, 'Inventory Name', {'class': 'form-label fw-bold'}) }}
                        {{ form_widget(form.name, {
                            'attr': {
                                'class': 'form-control form-control-lg'
                            }
                        }) }}
                        {% if form.name.vars.errors %}
                            <div class="invalid-feedback d-block">
                                {% for error in form.name.vars.errors %}
                                    {{ error.message }}
                                {% endfor %}
                            </div>
                        {% endif %}
                    </div>

                    <div class="mb-4">
                        {{ form_label(form.description, 'Description', {'class': 'form-label fw-bold'}) }}
                        {{ form_widget(form.description, {
                            'attr': {
                                'class': 'form-control',
                                'rows': '4'
                            }
                        }) }}
                    </div>

                    <div class="mb-4">
                        {{ form_label(form.accessLevel, 'Access Level', {'class': 'form-label fw-bold'}) }}
                        {{ form_widget(form.accessLevel, {
                            'attr': {
                                'class': 'form-select form-select-lg'
                            }
                        }) }}
                    </div>

                    <div class="mb-4">
                        <label class="form-label fw-bold">Custom Fields (JSON)</label>
                        {{ form_widget(form.customFields, {
                            'attr': {
                                'class': 'form-control font-monospace',
                                'rows': '4'
                            }
                        }) }}
                    </div>

                    <hr class="my-5">

                    <div class="d-flex justify-content-between align-items-center">
                        <a href="{{ path('inventory_show', { id: inventory.id }) }}" class="btn btn-outline-secondary">
                            <i class="fas fa-arrow-left"></i> Cancel
                        </a>
                        <button type="submit" class="btn btn-primary">
                            <i class="fas fa-save"></i> Save Changes
                        </button>
                    </div>

                    {{ form_end(form) }}
                </form>
            </div>
        </div>
    </div>
</div>
{% endblock %}
