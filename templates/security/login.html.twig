{% extends 'base.html.twig' %}

{% block title %}Login - Inventory Manager{% endblock %}

{% block body %}
<div class="row justify-content-center mt-5">
    <div class="col-md-6 col-lg-5">
        <div class="card shadow-lg border-0">
            <div class="card-body p-5">
                <div class="text-center mb-4">
                    <i class="fas fa-sign-in-alt text-primary" style="font-size: 3rem;"></i>
                    <h2 class="card-title mt-3">Welcome Back</h2>
                    <p class="text-muted">Login to your inventory</p>
                </div>
                
                {% if error %}
                    <div class="alert alert-danger alert-dismissible fade show" role="alert">
                        <i class="fas fa-exclamation-circle"></i> <strong>Login Failed!</strong>
                        {{ error.messageKey|trans(error.messageData, 'security') }}
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                {% endif %}
                
                <form method="post" novalidate>
                    <!-- Email Field -->
                    <div class="mb-3">
                        <label for="inputEmail" class="form-label fw-bold">Email Address</label>
                        <input type="email" id="inputEmail" name="email" class="form-control form-control-lg" 
                               value="{{ last_username }}" placeholder="your@email.com" required autofocus>
                    </div>
                    
                    <!-- Password Field -->
                    <div class="mb-4">
                        <label for="inputPassword" class="form-label fw-bold">Password</label>
                        <input type="password" id="inputPassword" name="password" class="form-control form-control-lg" 
                               placeholder="Enter your password" required>
                    </div>
                    
                    <!-- CSRF Token (Hidden) -->
                    <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">
                    
                    <!-- Remember Me -->
                    <div class="mb-4 form-check">
                        <input type="checkbox" class="form-check-input" id="remember" name="_remember_me">
                        <label class="form-check-label" for="remember">
                            Remember me
                        </label>
                    </div>
                    
                    <!-- Submit Button -->
                    <button type="submit" class="btn btn-primary btn-lg w-100 fw-bold">
                        <i class="fas fa-key"></i> Login
                    </button>
                </form>
                
                <hr class="my-4">
                
                <!-- Register Link -->
                <p class="text-center mb-0">
                    Don't have an account? 
                    <a href="{{ path('app_registration') }}" class="fw-bold text-decoration-none">Register here</a>
                </p>
            </div>
        </div>
    </div>
</div>
{% endblock %}
