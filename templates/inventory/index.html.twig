{% extends 'base.html.twig' %}

{% block title %}My Inventories - Inventory Manager{% endblock %}

{% block body %}
<div class="d-flex justify-content-between align-items-center mb-5">
    <div>
        <h1 class="mb-0">
            <i class="fas fa-boxes text-primary"></i> My Inventories
        </h1>
        <p class="text-muted mt-2">Manage and organize your inventory items</p>
    </div>
    <a href="{{ path('inventory_new') }}" class="btn btn-primary btn-lg">
        <i class="fas fa-plus-circle"></i> New Inventory
    </a>
</div>

{% if inventories is empty %}
    <div class="row">
        <div class="col-md-8 offset-md-2">
            <div class="alert alert-info text-center py-5" role="alert">
                <i class="fas fa-inbox" style="font-size: 3rem; color: #0dcaf0;"></i>
                <h5 class="mt-3">No Inventories Yet</h5>
                <p class="mb-0">Create your first inventory to get started!</p>
                <a href="{{ path('inventory_new') }}" class="btn btn-primary mt-3">
                    <i class="fas fa-plus"></i> Create First Inventory
                </a>
            </div>
        </div>
    </div>
{% else %}
    <div class="row g-4">
        {% for inventory in inventories %}
            <div class="col-md-6 col-lg-4">
                <div class="card h-100 shadow-sm border-0 hover-card">
                    <div class="card-body">
                        <!-- Header -->
                        <div class="d-flex justify-content-between align-items-start mb-3">
                            <h5 class="card-title mb-0">{{ inventory.name }}</h5>
                            <span class="badge bg-primary">v{{ inventory.version }}</span>
                        </div>
                        
                        <!-- Description -->
                        {% if inventory.description %}
                            <p class="card-text text-muted small mb-3">
                                {{ inventory.description[:100] }}{% if inventory.description|length > 100 %}...{% endif %}
                            </p>
                        {% else %}
                            <p class="card-text text-muted small mb-3 fst-italic">No description</p>
                        {% endif %}
                        
                        <!-- Meta Info -->
                        <div class="small text-muted mb-3">
                            <p class="mb-1">
                                <i class="fas fa-shield-alt"></i> 
                                <strong>Access Level:</strong> {{ inventory.accessLevel }}
                            </p>
                            <p class="mb-1">
                                <i class="fas fa-calendar"></i> 
                                <strong>Created:</strong> {{ inventory.createdAt|date('M d, Y') }}
                            </p>
                            <p class="mb-0">
                                <i class="fas fa-box"></i> 
                                <strong>Items:</strong> {{ inventory.items|length }}
                            </p>
                        </div>
                    </div>
                    
                    <!-- Card Footer with Actions -->
                    <div class="card-footer bg-transparent border-top">
                        <div class="d-flex gap-2">
                            <a href="{{ path('inventory_show', { id: inventory.id }) }}" class="btn btn-sm btn-outline-primary flex-fill">
                                <i class="fas fa-eye"></i> View
                            </a>
                            <a href="{{ path('inventory_edit', { id: inventory.id }) }}" class="btn btn-sm btn-outline-secondary flex-fill">
                                <i class="fas fa-edit"></i> Edit
                            </a>
                            <form method="post" action="{{ path('inventory_delete', { id: inventory.id }) }}" class="flex-fill" onsubmit="return confirm('Are you sure you want to delete this inventory?');">
                                <input type="hidden" name="token" value="{{ csrf_token('delete-inventory-' ~ inventory.id) }}">
                                <button class="btn btn-sm btn-outline-danger w-100">
                                    <i class="fas fa-trash"></i> Delete
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        {% endfor %}
    </div>
{% endif %}
{% endblock %}

{% block extra_css %}
<style>
    .hover-card {
        transition: transform 0.2s, box-shadow 0.2s;
    }
    
    .hover-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 0.5rem 1rem rgba(0, 0, 0, 0.15) !important;
    }
</style>
{% endblock %}
